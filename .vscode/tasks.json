{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "dotnet",
      "task": "build",
      "problemMatcher": ["$msCompile"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "label": "dotnet: build"
    },
    {
      "type": "shell",
      "command": "dotnet",
      "args": [
        "format",
        "XperienceCommunity.FieldPermissions.slnx",
        "--exclude",
        "./examples/**"
      ],
      "problemMatcher": ["$msCompile"],
      "group": "none",
      "label": "dotnet: format"
    },
    {
      "type": "dotnet",
      "task": "clean",
      "problemMatcher": ["$msCompile"],
      "group": "build",
      "label": "dotnet: clean"
    },
    {
      "label": "dotnet: watch DancingGoat",
      "command": "dotnet",
      "type": "process",
      "args": [
        "watch",
        "run",
        "--project",
        "${workspaceFolder}/examples/DancingGoat/DancingGoat.csproj"
      ],
      "options": {
        "env": {
          "DOTNET_WATCH_RESTART_ON_RUDE_EDIT": "true"
        }
      },
      "problemMatcher": "$msCompile"
    }
  ]
}
